{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/stands/how-to-get-stand.html",
      "destination": "/stands/how-to-get-stand/",
      "permanent": true
    },
    {
      "source": "/stands/stand-abilities.html",
      "destination": "/stands/stand-abilities/",
      "permanent": true
    },
    {
      "source": "/stands/discord-coordination.html",
      "destination": "/stands/discord-coordination/",
      "permanent": true
    },
    {
      "source": "/stands/corpse-part-guide.html",
      "destination": "/stands/corpse-part-guide/",
      "permanent": true
    },
    {
      "source": "/stands/faq.html",
      "destination": "/stands/faq/",
      "permanent": true
    },
    {
      "source": "/stands/stand-tier-list.html",
      "destination": "/stands/stand-tier-list/",
      "permanent": true
    },
    {
      "source": "/weapons/primary-weapons.html",
      "destination": "/weapons/primary-weapons/",
      "permanent": true
    },
    {
      "source": "/weapons/secondary-weapons.html",
      "destination": "/weapons/secondary-weapons/",
      "permanent": true
    },
    {
      "source": "/weapons/weapon-mechanics.html",
      "destination": "/weapons/weapon-mechanics/",
      "permanent": true
    }
  ]
}
